{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:DeleteObject",
        "s3:GetObject",
        "s3:PutObject",
        "s3:GetObjectTagging"
      ],
      "Resource": [
        "${aws_s3_arn}/dev/*",
        "${dev_bucket_arn}/*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:GetBucketVersioning",
        "s3:GetEncryptionConfiguration",
        "s3:ListBucketVersions"
      ],
      "Resource": "${dev_bucket_arn}/*"
    },
    {
      "Effect": "Allow",
      "Action":[
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:GetBucketVersioning",
        "s3:GetEncryptionConfiguration",
        "s3:ListBucketVersions"
      ],
      "Resource": "${aws_s3_arn}",
      "Condition": {
        "StringLike": {
          "s3:prefix": [ "dev/*" ]
        }
      }
    }
  ]
}