{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "AWS": "${dev_role_arn}"
      },
      "Action": [
        "s3:DeleteObject",
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "${dev_bucket_arn}/*"
    },
    {
      "Effect": "Allow",
      "Principal": "*",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "${dev_bucket_arn}/*"
    },
    {
      "Effect": "Deny",
      "Principal": "*",
      "Action": "*",
      "Resource": "${dev_bucket_arn}/private/*",
      "Condition": {
        "Null":{
          "aws:PrincipalArn": "true"
        },
        "StringNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::${aws_id}:role/${role_name}",
            "arn:aws:sts::${aws_id}:assumed-role/${role_name}/GitHubActions"
          ]
        }
      }
    }
  ]
}